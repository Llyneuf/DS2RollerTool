<Window x:Class="DS2Roller.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Dark Souls II Roller by Llyneuf"
        Icon="pack://application:,,,/DS2Roller;component/Assets/Images/favicon.ico"
        Height="360"
        Width="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">

    <Grid Margin="0">
        <Grid.Background>
            <ImageBrush ImageSource="pack://application:,,,/DS2Roller;component/Assets/Images/background.jpg" Stretch="UniformToFill"/>
        </Grid.Background>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <TextBlock Text="DARK SOULS II"
                   Foreground="#C9A86A"
                   FontSize="32"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>
        
        <TextBlock Text="DARK SOULS II"
                   Foreground="#a17d3a"
                   Padding="2"
                   FontSize="32"
                   Opacity="0.5"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"/>
        
        <TextBlock Text="Llyneuf"
                   Foreground="#C9A86A"
                   FontSize="24"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Padding="34"
                   VerticalAlignment="Bottom"/>

        <!-- Контент -->
        <StackPanel Grid.Row="1" VerticalAlignment="Bottom">

            <Border Background="#2A2A2A" Padding="12" CornerRadius="0" Opacity="0.9">
                <TextBlock x:Name="ClassText"
                           Text="Класс: ???"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Opacity="1"/>
            </Border>

            
            
            <Border Background="#2A2A2A" Padding="12" CornerRadius="0" Opacity="0.9">
                <TextBlock x:Name="GiftText"
                           Text="Начальный дар: ???"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="White"
                           Opacity="1"/>
            </Border>

        </StackPanel>

        <!-- Кнопка -->
        <Button x:Name="RollButton"
                Grid.Row="2"
                Content="ROLL DESTINY"
                Height="48"
                Margin="0,20,0,0"
                Background="#3A3A3A"
                Foreground="#C9A86A"
                FontSize="32"
                Opacity="1"
                Click="Roll_Click"/>
    </Grid>
</Window>
